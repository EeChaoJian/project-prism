# Project Prism — environment variables
#
# The boardroom (/api/boardroom) uses Fireworks AI to generate the CFO and
# Collections Manager analysis. If no key is set, the app automatically falls
# back to the static mock boardroom, so it still runs end to end without one.
#
# Copy this file to `.env.local` and fill in your key:
#   cp .env.example .env.local

# Your Fireworks API key (https://fireworks.ai). Leave blank to use fallback.
FIREWORKS_API_KEY=

# Optional: override the model. Defaults to the value below if unset.
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m3
